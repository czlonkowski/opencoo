{
  "name": "@opencoo/converter-docling",
  "version": "0.0.0",
  "private": true,
  "description": "Document → Markdown converter adapter backed by a Docling sidecar. Implements `DocumentConverterAdapter` from @opencoo/shared.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/mock-client.d.ts",
      "default": "./dist/testing/mock-client.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@opencoo/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  }
}
