{
  "name": "@opencoo/wiki-gitea",
  "version": "0.0.0",
  "private": true,
  "description": "WikiAdapter implementation backed by Gitea's REST API. The sanctioned transport tier under @opencoo/shared/wiki-write — orchestrator (queue, retries, delete-cap, commit-message build) stays in shared; this package owns the wire calls.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/mock-client.d.ts",
      "default": "./dist/testing/mock-client.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run tests/wiki-gitea.contract.test.ts"
  },
  "dependencies": {
    "@opencoo/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  }
}
